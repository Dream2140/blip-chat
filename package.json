{
  "name": "chat-app",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/web",
    "packages/ws"
  ],
  "scripts": {
    "dev": "concurrently -n web,ws -c blue,green \"npm run dev -w packages/web\" \"npm run dev -w packages/ws\"",
    "build": "npm run build -w packages/shared && npm run build -w packages/web && npm run build -w packages/ws",
    "dev:web": "npm run dev -w packages/web",
    "dev:ws": "npm run dev -w packages/ws",
    "db:migrate": "npm run db:migrate -w packages/web",
    "db:push": "npm run db:push -w packages/web",
    "db:studio": "npm run db:studio -w packages/web",
    "test:e2e": "npx playwright test",
    "test:e2e:prod": "TEST_URL=https://blip-chat-web.fly.dev npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.2",
    "playwright": "^1.59.1",
    "typescript": "^5.7.3"
  }
}
